rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny — reject all access not explicitly permitted below.
    match /{document=**} {
      allow read, write: if false;
    }

    // config/system — read-only for authenticated users (maintenance_mode flag).
    // Writes are performed exclusively by Cloud Functions via Admin SDK (bypasses rules).
    match /config/system {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Per-user subtree — authenticated users can only access their own documents.
    // Cloud Functions use the Admin SDK which bypasses these rules by design.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
